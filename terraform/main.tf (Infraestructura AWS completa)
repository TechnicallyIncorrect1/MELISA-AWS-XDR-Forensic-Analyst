# ================================================
# MELISA-AGENTIC AWS XDR Infrastructure
# ================================================

provider "aws" {
  region = "us-east-1"
}

# S3 Bucket for Forensics (Secure Storage)
resource "aws_s3_bucket" "melisa_forensic" {
  bucket = "melisa-forensic-bucket-${random_id.suffix.hex}"
  force_destroy = true

  tags = {
    Name        = "MELISA Forensic Bucket"
    Project     = "MELISA-AGENTIC"
    Owner       = "Francisco & Melissa"
  }
}

resource "random_id" "suffix" {
  byte_length = 4
}

# GuardDuty Detector
resource "aws_guardduty_detector" "melisa_detector" {
  enable = true
}

# Security Hub
resource "aws_securityhub_account" "melisa_securityhub" {}

# IAM Role for Lambda (MELISA Execution)
resource "aws_iam_role" "melisa_lambda_role" {
  name = "melisa-xdr-lambda-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Action = "sts:AssumeRole"
      Effect = "Allow"
      Principal = { Service = "lambda.amazonaws.com" }
    }]
  })
}

# Lambda Function (Core Engine)
resource "aws_lambda_function" "melisa_core" {
  filename         = "lambda.zip"
  function_name    = "melisa-xdr-core"
  role            = aws_iam_role.melisa_lambda_role.arn
  handler         = "bootstrap"
  runtime         = "provided.al2023"
  memory_size     = 1024
  timeout         = 300

  environment {
    variables = {
      MELISA_FORENSIC_BUCKET = aws_s3_bucket.melisa_forensic.id
    }
  }
}

output "melisa_forensic_bucket" {
  value = aws_s3_bucket.melisa_forensic.id
}

output "melisa_lambda_arn" {
  value = aws_lambda_function.melisa_core.arn
}
