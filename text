### 4. **GitHub Actions Pipeline Completo** (`.github/workflows/build-all.yml`)

```yaml
name: MELISA ULTIMATE MULTI-LANGUAGE BUILD

on:
  push:
    branches: [ main ]
  pull_request:

jobs:
  build-rust:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: dtolnay/rust-toolchain@stable
      - run: cd src/rust && cargo build --release

  build-go:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
      - run: cd src/go && go build -o melisa-xdr main.go

  build-java:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-java@v4
        with: { java-version: '21' }
      - run: cd src/java && javac *.java

  build-csharp:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-dotnet@v4
      - run: cd src/csharp && dotnet build

  deploy:
    needs: [build-rust, build-go, build-java, build-csharp]
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: aws-actions/configure-aws-credentials@v4
        with:
          aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
          aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
          aws-region: us-east-1
      - run: terraform -chdir=terraform apply -auto-approve
