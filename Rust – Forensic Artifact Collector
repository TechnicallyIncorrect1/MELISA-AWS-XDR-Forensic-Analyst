// src/forensic_collector.rs
use aws_sdk_s3::{Client as S3Client, primitives::ByteStream};
use aws_sdk_guardduty::Client as GuardDutyClient;
use serde_json::Value;
use std::error::Error;

#[tokio::main]
async fn main() -> Result<(), Box<dyn Error>> {
    let config = aws_config::load_from_env().await;
    let s3 = S3Client::new(&config);
    let guardduty = GuardDutyClient::new(&config);

    println!("🚀 MELISA Rust Forensic Collector Started (Memory Safe - Trellix Style)");

    let findings = guardduty.list_findings()
        .detector_id("default")
        .send()
        .await?;

    for finding_id in findings.finding_ids.unwrap_or_default() {
        let detail = guardduty.get_findings()
            .detector_id("default")
            .finding_ids(finding_id)
            .send()
            .await?;

        if let Some(finding) = detail.findings {
            let artifact = serde_json::to_vec(&finding)?;
            let key = format!("forensics/{}.json", chrono::Utc::now().timestamp());

            s3.put_object()
                .bucket("melisa-forensic-bucket")
                .key(&key)
                .body(ByteStream::from(artifact))
                .send()
                .await?;

            println!("✅ Forensic artifact saved: {}", key);
        }
    }

    Ok(())
}
